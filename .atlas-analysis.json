  "keyFeatures": [
    "Visual graph visualization of C2 beacons, hosts, and teamservers",
    "Red Team mode for importing and annotating Cobalt Strike, Brute Ratel, and Sliver logs",
    "Blue Team mode for reviewing curated and exported campaign data in read-only view",
    "Timeline scrubber to replay attack activities chronologically",
    "Full-text search across beacons, hosts, operators, commands, and tags",
    "MITRE ATT&CK technique tagging and annotation on commands",
    "Presentation mode to create slideshow-style reports from annotated comments",
    "Campaign export and anonymization for Blue Team handoff",
    "Extensible custom parser system supporting any C2 framework",
    "Docker and cross-platform binary deployment (Linux, macOS, Windows)"
  ],
  "publicApiSurface": [
    "GraphQL Query: campaigns",
    "GraphQL Query: campaign(campaignId)",
    "GraphQL Query: beacons(campaignId, hidden)",
    "GraphQL Query: hosts(campaignId)",
    "GraphQL Query: annotations(campaignId)",
    "GraphQL Query: commandGroups(campaignId, ...filters)",
    "GraphQL Query: servers(campaignId)",
    "GraphQL Query: operators(campaignId)",
    "GraphQL Query: timeline(campaignId)",
    "GraphQL Query: presentations(campaignId)",
    "GraphQL Mutation: createCampaign(creatorName, name, parser)",
    "GraphQL Mutation: deleteCampaign(campaignId)",
    "GraphQL Mutation: renameCampaign(campaignId, name)",
    "GraphQL Mutation: addCommandGroupAnnotation(campaignId, commandIds, tags, text, user)",
    "GraphQL Mutation: updateAnnotation(annotationId, campaignId, ...)",
    "GraphQL Mutation: deleteAnnotation(annotationId, campaignId)",
    "GraphQL Mutation: toggleBeaconHidden(campaignId, beaconId, setHidden)",
    "GraphQL Mutation: anonymizeCampaign(campaignId, anonymizeOptions)",
    "GraphQL Mutation: updateBeaconMetadata(beaconId, campaignId, ...)",
    "GraphQL Mutation: updateHostMetadata(hostId, campaignId, ...)",
    "Parser CLI: <parser-name> info",
    "Parser CLI: <parser-name> parse-campaign --folder <path>"
  ]
